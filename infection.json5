{
    "$schema": "https://raw.githubusercontent.com/infection/infection/0.32/resources/schema.json",
    "source": {
        "directories": ["src"]
    },
    "mutators": {
        "@default": true
    },
    "testFramework": "phpunit",
    "logs": {
        "text": "build/infection.txt",
        "html": "build/infection.html",
        "summary": "build/infection-summary.txt"
    },
    "minMsi": 100,
    "minCoveredMsi": 100
}
