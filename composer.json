{
    "name": "temporal/temporal",
    "description": "PHP implementation of the TC39 Temporal API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "carthage-software/mago": "^1.13",
        "infection/infection": "^0.32",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0",
        "psalm/plugin-phpunit": "^0.19",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Temporal\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Temporal\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit tests/",
        "test-coverage": "phpunit tests/ --coverage-xml build/coverage/coverage-xml --log-junit build/coverage/junit.xml",
        "infection": "infection --threads=max",
        "phpstan": "phpstan analyse",
        "psalm": "psalm",
        "mago": [
            "mago lint",
            "mago analyze"
        ],
        "mago-format": "mago format",
        "mago-check": "mago format --check",
        "check": [
            "@phpstan",
            "@psalm",
            "@mago",
            "@mago-check",
            "@test-coverage",
            "infection --threads=max --coverage=build/coverage --skip-initial-tests"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true,
            "phpstan/extension-installer": true
        }
    }
}
